# Copia este archivo como .env y completa los valores
# Railway inyecta DATABASE_URL automáticamente cuando agregas el plugin PostgreSQL

# Base de datos (Railway lo pone solo si usas su plugin)
DATABASE_URL=postgresql://usuario:password@host:5432/riesgo_antioquia

# API keys IA
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# API keys institucionales — control administrativo único del desarrollador
# Ningún usuario necesita escribir ni ver estas claves
# Todos los usuarios autorizados (Google OAuth) se benefician automáticamente
#
# TomTom Traffic: developer.tomtom.com → My Apps → New App → Traffic API
# Plan gratuito: 2,500 req/día
TOMTOM_API_KEY=
#
# Tomorrow.io clima hiperlocal: tomorrow.io → Sign Up → Free plan (500 req/día)
TOMORROW_IO_API_KEY=
#
# HERE Technologies tráfico y rutas: developer.here.com → Crear proyecto → API Keys
# Plan gratuito: 30,000 transacciones/mes
HERE_API_KEY=
#
# GloFAS / Copernicus CDS: cds.climate.copernicus.eu → Registrarse → API Key
# Requiere aceptar términos del dataset GloFAS
COPERNICUS_API_KEY=

# Notificaciones email
RESEND_API_KEY=

# Entorno
ENV=production
